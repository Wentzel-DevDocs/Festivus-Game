# ──────────────────────────────────────────────────────────────────────────────
# Justin's Feats of Strength — environment variables
# Copy this file to `.env.local` (Next.js) and fill in real values.
# Everything works with NO env vars for a quick local demo — the game just
# skips durable storage (no leaderboard persistence) until DATABASE_URL is set.
#
# The realtime room is a small Node server (server/game/server.ts) that runs
# on any always-on host (Railway/Render/Fly). The BROWSER needs
# NEXT_PUBLIC_GAME_SERVER_URL (below). The room SERVER reads APP_BASE_URL and
# INTERNAL_API_SECRET from its own host's env (set them on Railway, not here).
# ──────────────────────────────────────────────────────────────────────────────

# ── Neon (Postgres) ───────────────────────────────────────────────────────────
# Connection string from https://console.neon.tech → your project → "Connect".
# Used by Drizzle (migrations, seed) and the Next.js API routes.
# SERVER-SIDE ONLY. Never expose with a NEXT_PUBLIC_ prefix.
DATABASE_URL=

# ── Internal API auth ─────────────────────────────────────────────────────────
# Shared secret the room server sends when POSTing match results to the
# Next.js API. Generate one with: openssl rand -hex 24
# Must be the SAME value on Vercel (this app) and on the room host (Railway).
INTERNAL_API_SECRET=

# Where the room server can reach the Next.js app (for saving results and
# loading level config). Local dev default shown; in production this is your
# Vercel URL, e.g. https://feats.example.com. Set it on the room host (Railway).
# Optional — the room plays fine without it, just no durable leaderboard writes.
APP_BASE_URL=http://localhost:3000

# ── Realtime room server ──────────────────────────────────────────────────────
# Where BROWSERS connect for the realtime room — the full URL of the room
# server (server/game/server.ts). Ships to the browser by design.
# Local dev:  http://127.0.0.1:1999   (the default when unset; `pnpm dev:server`)
# Production: your Railway URL, e.g. https://festivus-room.up.railway.app
NEXT_PUBLIC_GAME_SERVER_URL=http://127.0.0.1:1999

# The room server itself reads PORT (host-provided) and APP_ORIGIN (CORS
# allow-origin for the browser; defaults to *). Set APP_ORIGIN on Railway to
# your Vercel URL to lock it down if you like.
# APP_ORIGIN=https://feats.example.com

# ── Game cosmetics ────────────────────────────────────────────────────────────
# A photo of the boss's face. Leave empty to draw a placeholder head.
# When set, the face is cropped onto the swimmer, climber, pinned figure and
# the jack-in-the-box.
NEXT_PUBLIC_JUSTIN_PHOTO_URL=

# What everyone calls the protagonist.
NEXT_PUBLIC_BOSS_NAME=Justin

# ── Testing only ──────────────────────────────────────────────────────────────
# Divides every phase duration so a whole match runs in seconds. Used by
# `pnpm sim` (which sets 8). Leave unset for real play.
# FESTIVUS_TIME_SCALE=1
