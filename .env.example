# ──────────────────────────────────────────────────────────────────────────────
# Justin's Feats of Strength — environment variables
# Copy this file to `.env.local` (Next.js) and fill in real values.
# The Rivet actor process (pnpm dev:rivet) also reads `.env.local` via dotenv.
# Everything works with NO env vars for a quick local demo — the game just
# skips durable storage (no leaderboard persistence) until DATABASE_URL is set.
# ──────────────────────────────────────────────────────────────────────────────

# ── Neon (Postgres) ───────────────────────────────────────────────────────────
# Connection string from https://console.neon.tech → your project → "Connect".
# Used by Drizzle (migrations, seed) and the Next.js API routes.
# SERVER-SIDE ONLY. Never expose with a NEXT_PUBLIC_ prefix.
DATABASE_URL=

# ── Internal API auth ─────────────────────────────────────────────────────────
# Shared secret the Rivet actor sends when POSTing match results to the
# Next.js API. Generate one with: openssl rand -hex 24
# Must be set to the SAME value for the Vercel app and the Rivet actor.
INTERNAL_API_SECRET=

# Where the Rivet actor can reach the Next.js app (for saving results and
# loading level config). Local dev default shown; in production this is your
# Vercel URL, e.g. https://feats.example.com
APP_BASE_URL=http://localhost:3000

# ── Rivet (realtime room) ─────────────────────────────────────────────────────
# Where BROWSERS connect for the realtime room.
# Local dev: the embedded RivetKit engine started by `pnpm dev:rivet`.
# Production: your Rivet Cloud endpoint (see README → Deploy).
NEXT_PUBLIC_RIVET_ENDPOINT=http://127.0.0.1:6420

# Optional: only needed if your Rivet namespace requires a client token.
# Use a PUBLISHABLE token here (it is shipped to browsers) — never the
# secret admin token.
NEXT_PUBLIC_RIVET_TOKEN=

# Server-side Rivet credentials used when deploying/running the actor against
# Rivet Cloud (not needed for local dev).
RIVET_ENDPOINT=
RIVET_TOKEN=
RIVET_NAMESPACE=

# Optional override for serverless self-registration. The /api/rivet route
# registers itself with Rivet as the namespace's "default" runner; on Vercel
# the URL is derived automatically (production deployments only). Set this
# only on non-Vercel hosts or custom domains, e.g.
# https://feats.example.com/api/rivet
RIVET_RUNNER_URL=

# Rivet ACCESS / Cloud API token (cloud_api_…). Server-side ONLY — this is a
# management credential that can reconfigure the whole namespace, so never
# expose it to browsers. When set, the /api/rivet route uses it to create the
# "default" serverless runner config automatically on deploy (the sk_/pk_
# connection tokens are data-plane only and cannot). Without it you must
# create that runner config in the Rivet dashboard instead.
RIVET_ACCESS_TOKEN=

# ── Game cosmetics ────────────────────────────────────────────────────────────
# A photo of the boss's face. Leave empty to draw a placeholder head.
# When set, the face is cropped onto the swimmer, climber, pinned figure and
# the jack-in-the-box.
NEXT_PUBLIC_JUSTIN_PHOTO_URL=

# What everyone calls the protagonist.
NEXT_PUBLIC_BOSS_NAME=Justin

# ── Testing only ──────────────────────────────────────────────────────────────
# Divides every phase duration so a whole match runs in seconds. Used by
# `pnpm sim` (which sets 8). Leave unset for real play.
# FESTIVUS_TIME_SCALE=1
