# ──────────────────────────────────────────────────────────────────────────────
# Justin's Feats of Strength — environment variables
# Copy this file to `.env.local` (Next.js) and fill in real values.
# Everything works with NO env vars for a quick local demo — the game just
# skips durable storage (no leaderboard persistence) until DATABASE_URL is set.
#
# The realtime room runs on PartyKit (a separate deploy). The BROWSER needs
# NEXT_PUBLIC_PARTYKIT_HOST (below). The PartyKit SERVER needs APP_BASE_URL and
# INTERNAL_API_SECRET — set those with `npx partykit env add <NAME>`, not here.
# ──────────────────────────────────────────────────────────────────────────────

# ── Neon (Postgres) ───────────────────────────────────────────────────────────
# Connection string from https://console.neon.tech → your project → "Connect".
# Used by Drizzle (migrations, seed) and the Next.js API routes.
# SERVER-SIDE ONLY. Never expose with a NEXT_PUBLIC_ prefix.
DATABASE_URL=

# ── Internal API auth ─────────────────────────────────────────────────────────
# Shared secret the PartyKit room server sends when POSTing match results to
# the Next.js API. Generate one with: openssl rand -hex 24
# Must be the SAME value on Vercel (this app) and on PartyKit
# (`npx partykit env add INTERNAL_API_SECRET`).
INTERNAL_API_SECRET=

# Where the PartyKit room server can reach the Next.js app (for saving results
# and loading level config). Local dev default shown; in production this is
# your Vercel URL, e.g. https://feats.example.com. Set on PartyKit with
# `npx partykit env add APP_BASE_URL`. Optional — the room plays fine without
# it, just without durable leaderboard writes.
APP_BASE_URL=http://localhost:3000

# ── PartyKit (realtime room) ──────────────────────────────────────────────────
# Where BROWSERS connect for the realtime room — the PartyKit HOST only (no
# protocol, no path). Ships to the browser by design (it's just a hostname).
# Local dev:  127.0.0.1:1999  (the default when unset; `pnpm dev:party`)
# Production: <project>.<github-username>.partykit.dev  (from `partykit deploy`)
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999

# ── Game cosmetics ────────────────────────────────────────────────────────────
# A photo of the boss's face. Leave empty to draw a placeholder head.
# When set, the face is cropped onto the swimmer, climber, pinned figure and
# the jack-in-the-box.
NEXT_PUBLIC_JUSTIN_PHOTO_URL=

# What everyone calls the protagonist.
NEXT_PUBLIC_BOSS_NAME=Justin

# ── Testing only ──────────────────────────────────────────────────────────────
# Divides every phase duration so a whole match runs in seconds. Used by
# `pnpm sim` (which sets 8). Leave unset for real play.
# FESTIVUS_TIME_SCALE=1
