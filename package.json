{
  "name": "justins-feats-of-strength",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Festivus-themed Jackbox-style party game: one boss on the big screen, everyone's phones deciding his fate.",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx watch server/game/server.ts",
    "dev:all": "concurrently -n next,room -c blue,magenta \"pnpm dev\" \"pnpm dev:server\"",
    "build": "next build",
    "start": "next start",
    "start:server": "tsx server/game/server.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "sim": "tsx scripts/simulate.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "drizzle-orm": "^0.44.2",
    "next": "^16.2.10",
    "pixi.js": "^8.6.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "concurrently": "^9.1.2",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3"
  }
}
